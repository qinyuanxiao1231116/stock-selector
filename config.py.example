import os

# Server酱推送密钥（https://sct.ftqq.com/）
# 免费每天5条，支持多人推送，每人一个 SendKey
_env_key = os.environ.get('SEND_KEY', '')
SEND_KEYS = [_env_key] if _env_key else [
    'YOUR_SEND_KEY_HERE',
    # 添加更多人的 SendKey：
    # 'ANOTHER_SEND_KEY_HERE',
]

# WxPusher推送配置（https://wxpusher.zjiecode.com/）
# 免费不限条数，需先在官网创建应用获取AppToken，用户扫码关注后获取UID
WXPUSHER_APP_TOKEN = os.environ.get('WXPUSHER_APP_TOKEN', '')  # 填入你的 AppToken，留空则不启用
WXPUSHER_UIDS = [
    # 'UID_xxxxxxxx',  # 每个关注用户一个UID
]

# 选股阈值参数
LIMIT_UP_THRESHOLD = 10000    # 涨停封单最小手数
GAP_THRESHOLD = 1.0           # 跳空高开最小百分比
BUY_VOLUME_THRESHOLD = 5000   # 抢筹买一量最小手数
BUY_PRICE_THRESHOLD = 2.0     # 抢筹涨幅最小百分比

# 日志文件路径
LOG_FILE = 'stock_selector.log'
